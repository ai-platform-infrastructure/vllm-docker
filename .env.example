COMPOSE_PROJECT_NAME=vllm_api
COMPOSE_DOMAIN=vllmapi.local.itkdev.dk
COMPOSE_LITELLM_DOMAIN=litellm.local.itkdev.dk

HUGGING_FACE_HUB_TOKEN=xxx

# Qwen3.5-122B MoE AWQ 4-bit for Blackwell RTX PRO 6000 (96GB VRAM)
# 128k context, conservative memory utilization for stability
VLLM_MODEL=cyankiwi/Qwen3.5-122B-A10B-AWQ-4bit
VLLM_OPTIONS=--max-model-len 131072 --gpu-memory-utilization 0.88 --enable-prefix-caching --kv-cache-dtype fp8 --max-num-seqs 12 --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder --mm-processor-kwargs '{"min_pixels":65536,"max_pixels":1048576}' --limit-mm-per-prompt '{"image":2}'
SHM_SIZE=32gb

# Blackwell cu130-nightly kernel settings
VLLM_USE_DEEP_GEMM=0
VLLM_USE_FLASHINFER_MOE_FP16=1
VLLM_USE_FLASHINFER_SAMPLER=0
OMP_NUM_THREADS=4

# Leave empty if you do not wish to use API key.
VLLM_API_KEY=

POSTGRES_PASSWORD=

LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
