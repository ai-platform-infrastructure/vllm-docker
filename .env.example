COMPOSE_PROJECT_NAME=vllm_api
COMPOSE_DOMAIN=vllmapi.local.itkdev.dk

HUGGING_FACE_HUB_TOKEN=xxx

# https://docs.vllm.ai/en/latest/models/engine_args.html
# Important: Set --gpu-memory-utilization per model to avoid OOM on shared GPU (e.g. 0.45 each).
VLLM_E5_MODEL=intfloat/multilingual-e5-large
VLLM_E5_OPTIONS="--task embedding --dtype float16 --max-model-len 512 --max-num-seqs 256 --max-num-batched-tokens 16384 --gpu-memory-utilization 0.45 --disable-log-requests"
SHM_E5_SIZE=8gb

VLLM_BGE_MODEL=BAAI/bge-m3
VLLM_BGE_OPTIONS="--task embedding --dtype float16 --max-model-len 2048 --max-num-seqs 64 --max-num-batched-tokens 8192 --gpu-memory-utilization 0.45 --disable-log-requests"
SHM_BGE_SIZE=8gb

# IP allowed to access /metrics endpoint.
NGINX_ALLOW_METRICS_IP=

# Leave empty if you do not wish to use API key.
VLLM_API_KEY=
